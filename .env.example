# =========================================
# Party App Backend — Environment Variables
# Copy to .env and fill in values
# =========================================

# Runtime
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# MongoDB — use your own cluster (Atlas or self-hosted)
MONGODB_URI=mongodb://localhost:27017/party_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Use DIFFERENT secrets for user vs admin (defense in depth)
# ---------------------------------------------------------------------------

# User auth
JWT_ACCESS_SECRET=change_me_user_access_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_user_refresh_secret_at_least_32_chars_long
JWT_REFRESH_EXPIRES=30d

# Admin auth (SEPARATE secrets)
JWT_ADMIN_ACCESS_SECRET=change_me_admin_access_secret_at_least_32_chars_long
JWT_ADMIN_ACCESS_EXPIRES=30m
JWT_ADMIN_REFRESH_SECRET=change_me_admin_refresh_secret_at_least_32_chars_long
JWT_ADMIN_REFRESH_EXPIRES=7d

# Security
BCRYPT_ROUNDS=12

# OTP
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Rate Limiting
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# Super Admin bootstrap (seeded on first boot if DB has no admins)
SUPER_ADMIN_EMAIL=admin@partyapp.com
SUPER_ADMIN_PASSWORD=ChangeMe!2026
SUPER_ADMIN_USERNAME=superadmin

# SMS (stub for dev)
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email — SMTP (Gmail app password works here)
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@partyapp.com
SENDGRID_API_KEY=

# Agora (fill when ready)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Cloudflare R2 (fill when ready)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
